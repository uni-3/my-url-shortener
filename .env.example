# Cloudflare Turnstile (Required for bot protection)
# Get keys from: https://dash.cloudflare.com/ > Turnstile
# For local dev, use the test keys below:
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Salt for hashing IP addresses (Required, e.g., generated by `openssl rand -hex 32`)
IP_SALT=development-salt-placeholder

# Google Safe Browsing API Key (Optional, skips safety check if not set)
GOOGLE_SAFE_BROWSING_API_KEY=

# Google Generative AI (Gemini) API Key (Required for the chat agent)
# Get a key from: https://aistudio.google.com/apikey
# 本番/dev は `wrangler secret put GOOGLE_GENERATIVE_AI_API_KEY` で設定する。
# ローカルの `wrangler dev` 用には `.dev.vars` に GOOGLE_GENERATIVE_AI_API_KEY=... を置く。
GOOGLE_GENERATIVE_AI_API_KEY=

# Cloudflare Credentials (Required for D1/KV operations and deployment)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_DATABASE_ID=your-database-id
CLOUDFLARE_D1_TOKEN=your-api-token

# OpenTelemetry / Grafana Monitoring (Optional)
GRAFANA_AUTH_TOKEN=your-base64-auth-token
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-northeast-0.grafana.net/otlp/v1/traces
OTEL_DEBUG=true
